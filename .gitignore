# Virtual Environments
.venv/
venv/
env/

# Security (NEVER UPLOAD THESE)
.env
.env.*

# Python Cache
__pycache__/
*.py[cod]
*$py.class

# Output Data & State (NEVER PUSH TO GITHUB)
data/
*.db
*.xlsx
*.csv

# Log data
logs/

# Ignore all JSONs globally...
*.json

# ...BUT explicitly protect our config file!
!config/companies.json
!config/cv_profile.json
!config/prompt_template.txt

# OS generated files
.DS_Store
Thumbs.db

# ADR documents
ADR/