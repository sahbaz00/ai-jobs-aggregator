# Virtual Environments
.venv/
venv/
env/

# Security (NEVER UPLOAD THESE)
.env
.env.*

# Python Cache
__pycache__/
*.py[cod]
*$py.class

# Output Data & State (NEVER PUSH TO GITHUB)
data/
*.db
*.xlsx
*.csv

# Ignore all JSONs globally...
*.json
